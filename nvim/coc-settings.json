{
  "biome.enable": true,
  "biome.requireConfiguration": true,

  // ESLint provides diagnostics and explicit fixes; Conform owns format-on-save.
  "eslint.enable": true,
  "eslint.format.enable": true,
  "eslint.filetypes": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc"
  ],
  "eslint.probe": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "json",
    "jsonc"
  ],

  // JSON fallback when ESLint/Biome aren’t active
  "json.format.enable": true,

  "typescript.format.enable": true,
  "javascript.format.enable": true,
  "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true
}
